{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "README.md",
      ".firebaserc",
      ".git",
      ".git/**",
      ".github",
      ".github/**",
      ".firebase",
      ".firebase/**",
      ".vercel",
      ".vercel/**",
      ".DS_Store",
      "**/.DS_Store",
      "firebase-debug.log",
      "*.log",
      ".env",
      ".env.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "trailingSlash": false
  }
}
